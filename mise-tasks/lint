#!/usr/bin/env bash
#MISE description="Run shellcheck over every tracked shell script (extension or shebang)"
#
# Discover scripts by .sh/.bash extension or a shell shebang, so the
# extension-less maintainer scripts (postinst, postrm, claude-code-termux-update)
# are covered and the set can't drift as scripts are added.
set -euo pipefail

git ls-files -z |
  while IFS= read -r -d '' f; do
    case $f in
      *.sh | *.bash) printf '%s\0' "$f" ;;
      *) [ -f "$f" ] && IFS= read -r line < "$f" &&
        case $line in '#!'*sh*) printf '%s\0' "$f" ;; esac ;;
    esac
  done |
  xargs -0 shellcheck
